# Rename this file to .env before running docker-compose

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=avalon123
MONGO_INITDB_DATABASE=avalon_game
MONGO_URL=mongodb://admin:avalon123@mongodb:27017/avalon_game?authSource=admin
DB_NAME=avalon_game

# Frontend nginx → backend proxy hostname
# docker-compose uses service name "backend"; k8s uses "avalon-backend"
BACKEND_HOST=backend

# Cloudflared tunnel token (optional, for remote access)
TUNNEL_TOKEN=
