FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY frontend/package.json frontend/yarn.lock ./

# Install dependencies
RUN yarn install --frozen-lockfile

# Copy frontend code
COPY frontend/ .

# Set environment variable
ENV REACT_APP_BACKEND_URL=http://localhost:8001

# Expose port
EXPOSE 3000

# Command to run the application
CMD ["yarn", "start"]